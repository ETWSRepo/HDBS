# Disable directory listing
Options -Indexes

# index.php is now the SPA entry point (formerly a static index.html)
DirectoryIndex index.php index.html

# Legacy bookmarks/cached links to index.html now redirect to the SPA root
RewriteEngine On
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Block direct access to internal PHP helpers
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>
<Files "applog.php">
    Order Allow,Deny
    Deny from all
</Files>

# Block sensitive files
<FilesMatch "(secrets\.php|\.ftp-credentials|\.env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block log and text files
<FilesMatch "\.(log|txt)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security headers
# Force HTTPS upgrade for accidental HTTP asset loads; restrict framing (clickjacking)
Header always set Content-Security-Policy "upgrade-insecure-requests; frame-ancestors 'self'"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# Disable LiteSpeed cache for JS, CSS, PHP
<IfModule LiteSpeed>
    RewriteEngine On
    CacheLookup off
</IfModule>

<FilesMatch "\.(js|css|php|html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
    Header unset Expires
</FilesMatch>
